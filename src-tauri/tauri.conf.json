{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.10.3/crates/tauri-config-schema/schema.json",
  "productName": "Watchman",
  "version": "1.0.1",
  "identifier": "app.blinkeye.watchman",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Watchman",
        "width": 520,
        "height": 780,
        "minWidth": 460,
        "minHeight": 650,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: https:; connect-src 'self' https:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "scripts/temperature_probe.ps1",
      "vendor/libre-hardware-monitor/*"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCMDNDMzM5NkFBREE3NDIKUldSQ3A2MXFPY01ENjY4Sm5QWW5FYXRLZk5uVkRBS25ZWkd5MldocEIwbWc1LzV2SkN5UEw0cDEK",
      "endpoints": [
        "https://github.com/rayhan138/Watchman/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
